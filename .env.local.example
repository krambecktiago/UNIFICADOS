# ============================================================
# SUPABASE — https://supabase.com/dashboard/project/<id>/settings/api
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Apenas para scripts server-side (não expor no frontend!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# GROQ — https://console.groq.com/keys
# ============================================================
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# PIX — Bradesco + ERP JJW (ferramenta "Conciliação PIX")
# ============================================================
BRADESCO_BASE_URL=https://proxy.api.prebanco.com.br
BRADESCO_CLIENT_ID=
BRADESCO_CLIENT_SECRET=
BRADESCO_CHAVE_PIX=
# Opcional — só se o Bradesco exigir mTLS (.p12 em base64)
BRADESCO_CERT_P12_BASE64=
BRADESCO_CERT_PASSWORD=
# Segredo compartilhado esperado no header x-webhook-token do push do Bradesco
PIX_WEBHOOK_TOKEN=

JJW_ERP_BASE_URL=
JJW_ERP_API_KEY=

PIX_MATCH_TOLERANCE_PCT=2
PIX_MATCH_TOLERANCE_DAYS=30
PIX_LOOKBACK_MINUTES=30
PIX_RECONCILE_BATCH_LIMIT=20
PIX_STALE_RECONCILING_MINUTES=5

# Bearer esperado em /api/pix/cron — configure o MESMO valor como secret
# PIX_CRON_SECRET no GitHub (Settings > Secrets > Actions), junto com
# PIX_CRON_URL apontando pra https://<seu-dominio>/api/pix/cron
PIX_CRON_SECRET=
